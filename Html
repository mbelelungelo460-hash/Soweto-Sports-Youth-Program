<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soweto Sports Youth Program</title><!-- Firebase --><script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script><script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script><script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script><style>
body { margin:0; font-family:Arial; background:linear-gradient(135deg,#ff9a9e,#fad0c4,#a6c1ee,#84fab0,#fbc2eb); }
header { background:#000; color:#fff; text-align:center; padding:30px; }
nav { background:#111; padding:12px; text-align:center; position:sticky; top:0; }
nav a { color:#fff; margin:0 12px; text-decoration:none; font-weight:bold; }
section { padding:30px; }
.card { background:#fff; padding:20px; margin:20px 0; border-radius:15px; box-shadow:0 5px 20px rgba(0,0,0,0.2);} 
.grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:20px; }
img { width:100%; height:180px; object-fit:cover; border-radius:10px; }
button { padding:12px; background:#ff512f; color:#fff; border:none; border-radius:8px; cursor:pointer; }
input, select { width:100%; padding:10px; margin:8px 0; }
.dashboard { background:#222; color:#fff; padding:20px; border-radius:10px; }
.hidden { display:none; }
</style></head>
<body><header>
<h1>🔥 Soweto Sports Youth Program 🔥</h1>
<p>Elite NGO Platform • Empowering Youth Through Sport</p>
</header><nav>
<a href="#sports">Sports</a>
<a href="#register">Register</a>
<a href="#dashboard">Dashboard</a>
<a href="#sponsors">Sponsors</a>
<a href="#donate">Donate</a>
</nav><section id="sports">
<h2>Sports Programs</h2>
<div class="grid">
<div class="card"><img src="https://images.unsplash.com/photo-1517927033932-b3d18e61fb3a"><h3>Football</h3></div>
<div class="card"><img src="https://images.unsplash.com/photo-1519861531473-9200262188bf"><h3>Basketball</h3></div>
<div class="card"><img src="https://images.unsplash.com/photo-1602216056096-3b40cc0c9944"><h3>Netball</h3></div>
<div class="card"><img src="https://images.unsplash.com/photo-1508609349937-5ec4ae374ebf"><h3>Athletics</h3></div>
</div>
</section><section id="register">
<h2>Register Player</h2>
<div class="card">
<form id="form">
<input type="text" id="name" placeholder="Full Name" required>
<input type="number" id="age" placeholder="Age" required>
<select id="sport"><option>Football</option><option>Basketball</option><option>Netball</option><option>Athletics</option></select>
<input type="text" id="guardian" placeholder="Parent Name" required>
<input type="tel" id="phone" placeholder="Phone" required>
<button type="submit">Register</button>
</form>
</div>
</section><section id="dashboard">
<h2>Admin Dashboard</h2>
<div class="dashboard">
<p>Total Players: <span id="total">0</span></p>
<ul id="list"></ul>
</div>
</section><section id="sponsors">
<h2>Sponsors & Partners</h2>
<div class="card">
<p>We welcome partnerships with brands, companies, and community leaders.</p>
<p>Contact us to become a sponsor and help grow youth talent.</p>
</div>
</section><section id="donate">
<div class="card">
<h2>Donate</h2>
<p>Account Name: Soweto Sports Youth Program</p>
<p>Account Number: 1055143890</p>
<p>Email: soweto.sports.youth.program@gmail.com</p>
<form action="https://www.payfast.co.za/eng/process" method="post">
<input type="hidden" name="merchant_id" value="34321277">
<input type="hidden" name="merchant_key" value="so9dayxzhaggc">
<input type="hidden" name="amount" value="100">
<input type="hidden" name="item_name" value="Donation">
<button type="submit">💳 Donate via PayFast</button>
</form>
</div>
</section><footer style="text-align:center; background:#000; color:#fff; padding:20px;">
© 2026 Soweto Sports Youth Program 🚀
</footer><script>
// 🔥 Firebase Config (REPLACE)
const firebaseConfig = {
  apiKey: "YOUR_KEY",
  authDomain: "YOUR_DOMAIN",
  projectId: "YOUR_PROJECT_ID"
};

firebase.initializeApp(firebaseConfig);
const db = firebase.firestore();

// REGISTER PLAYER
form.addEventListener("submit", async (e)=>{
  e.preventDefault();

  await db.collection("players").add({
    name: name.value,
    age: age.value,
    sport: sport.value,
    guardian: guardian.value,
    phone: phone.value
  });

  alert("✅ Registered!");
});

// LIVE DASHBOARD
const list = document.getElementById("list");
const total = document.getElementById("total");

db.collection("players").onSnapshot(snapshot=>{
  list.innerHTML = "";
  total.innerText = snapshot.size;

  snapshot.forEach(doc=>{
    const data = doc.data();
    const li = document.createElement("li");
    li.textContent = `${data.name} - ${data.sport}`;
    list.appendChild(li);
  });
});
</script></body>
</html>
